# Environment
ENV=development
PORT=3000

# Database
# PostgreSQL connection string
# Development: Use node-postgres (pg)
# Production: Use Neon serverless
DATABASE_URL=postgresql://user:password@localhost:5432/daggerheart_brews

# Authentication
# Generate a secure random string for BETTER_AUTH_SECRET
# Example: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# Discord OAuth (OPTIONAL — social login hidden when not configured)
# Get credentials from: https://discord.com/developers/applications
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# Google OAuth (OPTIONAL — social login hidden when not configured)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email (OPTIONAL — emails logged to console when not configured)
# Get API key from: https://resend.com/api-keys
# RESEND_API_KEY=
